# coverage_stats_run_001.npz
#
# NumPy archive placeholder — stores coverage statistics from simulation run 001.
# This file would be generated by analysis/coverage_analysis.py after processing
# data/logs/sim_run_001.bag.
#
# Contents (array names):
#   timestamps        : float64 [T]     — simulation time in seconds
#   coverage_fraction : float64 [T]     — fraction of free cells visited (0–1)
#   n_cells_explored  : int32   [T]     — absolute count of explored cells
#   robot_positions   : float64 [T, 2]  — (x, y) position of robot_0 over time
#   bandwidth_used    : float64 [T]     — cumulative bytes transmitted uplink
#   map_update_times  : float64 [U]     — timestamps of each map diff transmission
#   map_diff_sizes    : int32   [U]     — size of each map diff in bytes
#
# Shape summary (T=300 steps @ 1 Hz, U=~150 map update events):
#   timestamps        : (300,)
#   coverage_fraction : (300,)
#   n_cells_explored  : (300,)
#   robot_positions   : (300, 2)
#   bandwidth_used    : (300,)
#   map_update_times  : (148,)
#   map_diff_sizes    : (148,)
#
# To load:
#   import numpy as np
#   data = np.load("data/generated/coverage_stats_run_001.npz")
#   coverage = data["coverage_fraction"]
