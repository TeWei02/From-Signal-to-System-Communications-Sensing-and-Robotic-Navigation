# latency_vs_error.npz
#
# NumPy archive placeholder — stores latency-vs-navigation-error sweep results.
# Generated by analysis/plot_latency_vs_nav_error.py after sweeping base_latency_ms
# from 5 ms to 300 ms across N_TRIALS=5 Monte Carlo runs per setting.
#
# Contents:
#   latency_values_ms   : float64 [L]       — swept latency values (ms)
#   mean_nav_error_m    : float64 [L]       — mean position error at waypoints (m)
#   std_nav_error_m     : float64 [L]       — std dev of position error (m)
#   p95_nav_error_m     : float64 [L]       — 95th-percentile position error (m)
#   raw_errors          : float64 [L, N]    — per-trial errors (L latencies × N trials)
#   coverage_at_timeout : float64 [L]       — coverage fraction when max_steps reached
#
# Shape summary (L=12 latency settings, N=5 trials):
#   latency_values_ms   : (12,)
#   mean_nav_error_m    : (12,)
#   std_nav_error_m     : (12,)
#   p95_nav_error_m     : (12,)
#   raw_errors          : (12, 5)
#   coverage_at_timeout : (12,)
#
# To load:
#   import numpy as np
#   data = np.load("data/generated/latency_vs_error.npz")
#   plt.errorbar(data["latency_values_ms"], data["mean_nav_error_m"],
#                yerr=data["std_nav_error_m"])
